{
  "name": "exercise-6-docker-compose",
  "version": "1.0.0",
  "description": "Ćwiczenie 6: Docker Compose - Full Stack aplikacja z bazą danych",
  "main": "script.js",
  "scripts": {
    "build": "tsc script.ts",
    "start": "node script.js",
    "dev": "tsc script.ts && node script.js",
    "compose:up": "docker-compose up",
    "compose:up:build": "docker-compose up --build",
    "compose:up:detached": "docker-compose up -d",
    "compose:down": "docker-compose down",
    "compose:logs": "docker-compose logs",
    "compose:logs:follow": "docker-compose logs -f",
    "compose:restart": "docker-compose restart",
    "compose:clean": "docker-compose down -v --rmi all",
    "test:api": "curl -s http://localhost:3000/health && echo && curl -s http://localhost:3000/users && echo && curl -s http://localhost:3000/stats",
    "db:connect": "docker-compose exec db psql -U postgres -d app_db"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/pg": "^8.10.2",
    "@types/node": "^20.5.0",
    "typescript": "^5.0.0"
  }
}