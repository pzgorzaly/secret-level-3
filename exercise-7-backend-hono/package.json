{
  "name": "exercise-7-backend-hono",
  "version": "1.0.0",
  "description": "Ćwiczenie 7: Backend API z Hono Framework i PostgreSQL",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target node",
    "start": "node dist/server.js",
    "start:bun": "bun src/server.ts",
    "docker:build": "docker build -t hono-todos-api .",
    "docker:run": "docker run -p 4000:4000 --env-file .env hono-todos-api",
    "db:up": "docker-compose up db -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs db -f",
    "db:reset": "docker-compose down -v && docker-compose up db -d",
    "api:docker": "docker-compose --profile with-api up --build",
    "full:docker": "docker-compose --profile with-api --profile tools up --build",
    "setup": "npm run db:up && echo '⏳ Waiting for database...' && sleep 5",
    "test": "curl -s http://localhost:4000/health",
    "test:endpoints": "curl -s http://localhost:4000 && echo && curl -s http://localhost:4000/todos && echo && curl -s http://localhost:4000/stats",
    "db:connect": "docker-compose exec db psql -U postgres -d todos_db",
    "lint": "echo 'Linting Hono API...' && echo '✅ Code looks good!'",
    "format": "echo 'Formatting code...' && echo '✅ Code formatted!'"
  },
  "dependencies": {
    "hono": "^3.12.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/pg": "^8.10.2",
    "bun-types": "latest"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "keywords": [
    "hono",
    "api",
    "postgresql",
    "typescript",
    "crud",
    "todos",
    "backend"
  ]
}